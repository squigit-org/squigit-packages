[squigit-ocr]
name=Squigit OCR Packages
baseurl=https://github.com/squigit-org/squigit-packages/raw/main/rpm/ocr
enabled=1
gpgcheck=1
repo_gpgcheck=1
gpgkey=https://github.com/squigit-org/squigit-packages/raw/main/keys/squigit-packages.asc

[squigit-stt]
name=Squigit STT Packages
baseurl=https://github.com/squigit-org/squigit-packages/raw/main/rpm/stt
enabled=1
gpgcheck=1
repo_gpgcheck=1
gpgkey=https://github.com/squigit-org/squigit-packages/raw/main/keys/squigit-packages.asc
